build/
*.xcodeproj
.swiftpm/
.DS_Store

# Probe run captures (scratch — e.g. `swift run ZoomProbe … | tee logs/logzoom.md`)
/macos/logs/

# AXSnapshot output (full AX-tree dumps for analysis)
/ax-dumps/
/macos/ax-dumps/

# Native-Zoom live rig debug dumps (guest-join HTML + screenshots on failure —
# may show a meeting URL; regenerated per failing run). NEVER commit.
/qa/zoom-live/debug/

logs

# Live Meet rig runtime artifacts — Chrome profiles (may hold a signed-in session),
# captured meeting URL, and observation timelines. NEVER commit these.
/research/meet-dom-detector/live/.live-profile/
/research/meet-dom-detector/live/.rig-profiles/
/research/meet-dom-detector/live/.meeting-url
/research/meet-dom-detector/live/.rig-meeting-url
/research/meet-dom-detector/live/observe-timeline.jsonl
/research/meet-dom-detector/live/audio/*.wav
# fake-audio rig: generated speech WAVs + per-run results (regenerated by scripts)
/research/meet-dom-detector/live/fake-audio/*.wav
/research/meet-dom-detector/live/fake-audio-rig-results.json
# machine-specific discovered audio device index + per-run results (regenerated)
/research/meet-dom-detector/live/.audio-device-index
/research/meet-dom-detector/live/.bh-device-index
/research/meet-dom-detector/live/struct-loop-results.json
# Teams live rig per-run outputs — regenerated each run; the distilled numbers live
# in docs/teams-active-speaker-detection.md §9. NEVER commit raw traces.
/qa/teams-live/teams-live-results.ndjson
/qa/teams-live/teams-ring-probe-trace.ndjson
/qa/teams-live/teams-ring-probe-marks.json
/qa/teams-live/teams-throttle-trace.ndjson
/qa/teams-live/teams-axobserve-probe.log
